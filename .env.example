# Adaptateur actif :
#   canutes    → open data hackathon (recommandé) : résolution, application,
#                connexes, parlement via API Canutes ; jurisprudence via PISTE ;
#                doctrine via HAL.
#   reference  → tout via PISTE + HAL (sans Canutes).
#   silexia    → connecteurs MCP Silexia (premium, plugin privé).
BACKEND=canutes

# --- API Canutes-Légifrance (Tricoteuses/LegiWatch) — adaptateur canutes ---
# Licence Ouverte, sans clé. Confirmer l'URL de base sur la doc OpenAPI.
CANUTES_BASE_URL=https://api.canutes.tricoteuses.fr

# --- Légifrance / PISTE — requis pour le cluster JURISPRUDENCE uniquement ---
# Clé gratuite : https://piste.gouv.fr — données sous Licence Ouverte Etalab
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=

# --- Silexia (adaptateur premium, plugin privé optionnel) ---
SILEXIA_MCP_URL=https://mcp.silexia.legal/mcp

# --- Cache / démo ---
CACHE_DIR=data/cache
# DEMO_MODE=1 → lecture seule depuis le cache (pitch, aucun appel réseau live)
DEMO_MODE=0
