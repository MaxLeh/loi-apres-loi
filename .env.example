# Adaptateur actif :
#   reference  → 100 % open data (PISTE + HAL + parlement.tricoteuses.fr). Défaut.
#   silexia    → connecteurs MCP Silexia (premium, plugin privé optionnel).
BACKEND=reference

# --- Légifrance / PISTE — requis (application, jurisprudence, résolution) ---
# Clé gratuite : https://piste.gouv.fr — données sous Licence Ouverte Etalab.
PISTE_CLIENT_ID=
PISTE_CLIENT_SECRET=

# --- LLM (compréhension de la requête, classification, synthèse) ---
# Mistral (souveraineté FR). Sans clé → repli déterministe (HeuristicLLM).
# Clé : https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# --- Parlement (open data, sans clé) — surchargeable ---
PARLEMENT_API=https://parlement.tricoteuses.fr

# --- Silexia (adaptateur premium, plugin privé optionnel) ---
SILEXIA_MCP_URL=

# --- Cache / démo ---
CACHE_DIR=data/cache
# DEMO_MODE=1 → lecture seule depuis le cache (pitch, aucun appel réseau live)
DEMO_MODE=0
